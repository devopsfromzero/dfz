# ========================================
# DFZ — Environment overrides
# Copy to .env and edit as needed.
# All variables are optional; defaults shown in comments.
# ========================================

# ---- Access ----
# External URL the dashboard is served at (used for CORS + cookies).
# Use http://localhost:3080 for local install, or https://your.domain for TLS.
APP_URL=http://localhost:3080

# Host port mapping for the UI container (container listens on 3000).
UI_PORT=3080

# ---- Image tags ----
# Pin to a specific release instead of :latest for reproducible deploys.
# TAG=v0.1.0
# REGISTRY=ghcr.io/devopsfromzero

# ---- Cookies / TLS ----
# Set to true when serving over HTTPS (required if using a reverse proxy with TLS).
SECURE_COOKIES=false
# Options: strict | lax | none   (none requires SECURE_COOKIES=true)
COOKIE_SAMESITE=lax

# ---- Tokens ----
# ACCESS_TOKEN_EXPIRE_MINUTES=120
# REFRESH_TOKEN_EXPIRE_DAYS=7
# ENABLE_TOKEN_ROTATION=false

# ---- Logging ----
# LOG_LEVEL=WARNING   # DEBUG | INFO | WARNING | ERROR

# ---- Resource tuning (advanced) ----
# PG_POOL_MIN_SIZE=2
# PG_POOL_MAX_SIZE=20
# REDIS_MAXMEMORY=2gb
# THREAD_POOL_MAX_WORKERS=64
# INFORMER_PROCESS_SOFT_LIMIT_MB=1500
# INFORMER_PROCESS_HARD_LIMIT_MB=2000
